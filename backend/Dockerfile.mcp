FROM python:3.12-slim

WORKDIR /app

# MCP HTTP service: exposes the shared readings DB over the Model Context Protocol.
# Reads the same /data/readings.db the scanner writes — no dependency on server.py.
RUN pip install --no-cache-dir \
        "mcp>=1.0.0" \
        aiosqlite>=0.20.0

COPY database.py mcp_server.py ./

ENV MCP_TRANSPORT=streamable-http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8675 \
    DB_PATH=/data/readings.db

EXPOSE 8675

CMD ["python", "mcp_server.py"]
